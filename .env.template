# Portfolio Automation Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# MARKET DATA API
# ===========================================
# Financial Modeling Prep API Key (required — primary data source)
# Get your key at: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_api_key_here

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
# Gmail SMTP credentials (required for email reports)
# Use an App Password, NOT your regular Gmail password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_TO=recipient@example.com

# Legacy aliases still accepted by some tools:
# SMTP_HOST=smtp.gmail.com
# EMAIL_SENDER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password_here
# EMAIL_RECIPIENT=recipient@example.com

# ===========================================
# SCANNER — FMP (Financial Modeling Prep)
# ===========================================
# Required when scanner.enabled=true in config.json.
# The key is read from this variable ONLY — never hardcoded.
# Get a free/starter key at: https://financialmodelingprep.com/developer/docs/
# Free tier: 250 calls/day.  Bulk endpoints (profile/all, key-metrics-bulk)
# require a Starter plan (~$15/mo).  Quote batch endpoints are free-tier.
# FMP_API_KEY=your_fmp_key_here

# ===========================================
# OPTIONAL OVERRIDES
# ===========================================
# Global LLM provider override for the theme engine + AI agent.
# Precedence: CLI arg > STOCKBOT_LLM_PROVIDER > task-specific config > built-in fallback chain.
# Supported: ollama | anthropic | openai
STOCKBOT_LLM_PROVIDER=ollama

# Task-specific provider preferences belong in config.json / config/base.json, for example:
# "theme_engine": { "task_providers": { "daily": "ollama" } }
# "agent": { "task_providers": { "weekly": "ollama", "monthly": "anthropic", "maintainer": "anthropic", "standalone": "ollama" } }

# Ollama OpenAI-compatible settings
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3:4b
OLLAMA_API_KEY=ollama

# Anthropic overrides (optional)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI overrides (optional)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Override config file path
# CONFIG_PATH=/path/to/custom/config.json

# Override output directory
# OUTPUT_DIR=/path/to/output

# Enable debug logging
# DEBUG=true
