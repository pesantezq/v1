# Virtual environment
.venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Secrets / local config
.env
*.env.local

# Runtime data (state, caches, DB) — stored locally only.
# Anchored to repo root so package subdirectories can be named data/
# (e.g. gui_v2/data/ for the pure data-collection layer).
/data/

# Daily-check reports — operator-facing logbook containing live portfolio
# data (positions, weights, attribution). Generated by scripts/daily_check.sh.
/daily_checks/

# Log files
logs/

# All generated outputs (overwritten every run)
outputs/latest/
outputs/history/
outputs/evals/
outputs/policy/

# Daily update artifacts
daily_update/

# Backlog (runtime state)
backlog/

# Editor / IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

