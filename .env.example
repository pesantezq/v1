# =============================================================================
# StockBot Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Market Data APIs ---
# Financial Modeling Prep (primary data source)
FMP_API_KEY=

# Alpha Vantage (secondary / supplemental data)
ALPHA_VANTAGE_API_KEY=

# --- Email Delivery ---
# SMTP server hostname (e.g. smtp.gmail.com)
SMTP_SERVER=
# SMTP port: 587 for STARTTLS (recommended), 465 for SSL
SMTP_PORT=587
# Sender credentials
EMAIL_USER=
EMAIL_PASS=
# Recipient address for daily digest / alerts
EMAIL_TO=

# --- Runtime ---
# Set to "production" on the VPS; leave blank or "development" locally
STOCKBOT_ENV=production
# Flush Python stdout/stderr immediately (important for log tailing)
PYTHONUNBUFFERED=1
